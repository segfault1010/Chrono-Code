# ============================================================================
# Chronocode API — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# --- Google Gemini AI ---
GEMINI_API_KEY=your_key_here

# --- Git Clone Storage ---
# Directory where cloned repositories are stored temporarily.
# Relative to the api working directory or an absolute path.
CLONE_BASE_PATH=./tmp/clones

# --- Server ---
PORT=3001
NODE_ENV=development

# --- CORS ---
# Frontend origin allowed to make API requests.
CORS_ORIGIN=http://localhost:3000
