{
  "name": "chronocode",
  "version": "0.1.0",
  "private": true,
  "description": "Turn raw git history into the explanation a senior teammate would give you.",
  "scripts": {
    "dev:api": "pnpm --filter @chronocode/api dev",
    "dev:web": "pnpm --filter @chronocode/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
